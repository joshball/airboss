# direnv: per-worktree dev DB.
#
# When direnv is installed (`brew install direnv` plus a shell hook) and you
# `cd` into a worktree, this `.envrc` runs and exports a per-worktree
# DATABASE_URL so the worktree's `bun run db reset` and `bun run dev` use a
# DB scoped to the worktree's branch instead of the shared `airboss` DB the
# parent repo's `.env` would otherwise hand them.
#
# Without direnv this file is harmless: nothing reads it, and the script-
# side resolver (`scripts/lib/db-name.ts`) does the same derivation when
# called directly from `db.ts` etc.
#
# Override: export AIRBOSS_DB_NAME=somename (or DATABASE_URL=...) yourself
# and direnv will preserve it.

if [ -z "${AIRBOSS_DB_NAME:-}" ] && [ -z "${DATABASE_URL_OVERRIDE:-}" ]; then
  export DATABASE_URL="$(bun scripts/lib/db-name.ts --url 2>/dev/null)"
fi
