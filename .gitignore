node_modules/
dist/
build/
.svelte-kit/
.env
.env.local
.DS_Store
*.log
coverage/
# But not the Program "Coverage" sub-tab route -- that lives at
# `apps/study/src/routes/(app)/program/coverage/` and is real code, not a
# test-coverage artifact.
!apps/study/src/routes/(app)/program/coverage/
.tmp/
.claude/
.dev/
.cache/

# Playwright
/tests/e2e/.auth/
/tests/e2e/.out/
/tests/integration/.out/
/playwright-report/
/test-results/

# ADR 019 §2.5 -- generated registry snapshot for non-TypeScript consumers.
# Regenerated per environment via `bun scripts/airboss-ref.ts snapshot`.
data/sources-snapshot.json

# ADR 019 §5 -- annual rollover diff job reports. Regenerated per run via
# `bun scripts/airboss-ref.ts diff`. Operator-local artifacts.
data/sources-diff/*.json

# ADR 018 -- rendered SVG charts are generated artifacts and stay out of the
# repo. The v2 timeline bundle commits per-hour chart SPECS only; the replay
# surface renders them to SVG on demand. This blocks accidental staging of a
# rendered chart under any wx-scenario bundle.
data/wx-scenarios/**/*.svg

# Source artifact storage policy -- see ADR 018 and docs/platform/STORAGE.md.
# Source documents (FAA PDFs etc.) live in $AIRBOSS_HANDBOOK_CACHE
# (default ~/Documents/airboss-handbook-cache/), not the repo.
# These lines block accidental staging; the matching .gitattributes lines
# carry dormant LFS plumbing for the day this policy flips.
handbooks/**/*.pdf
regulations/cfr-*/**/*.xml
safo/**/*.pdf
info/**/*.pdf

# CFR per-section body markdown is generated/computed (5K+ files per title).
# Only manifest.json + sections.json are committed (structural index +
# body_sha256 audit trail). Bodies regenerate deterministically from the
# cached XML via `bun run ingest cfr`. See ADR 018 (scale exception).
regulations/cfr-*/**/*.md
.ball-coord/

# Per-section meta.json carries body_sha256 + last_amended_date that already
# live in the parent edition's sections.json; ingestion writes them locally
# but they're redundant for commit purposes.
regulations/cfr-*/**/*.meta.json

# scheduled-jobs cache (do not commit)
scripts/scheduler/.cache/

# scheduled-jobs per-machine config (regenerate via bootstrap)
scripts/scheduler/.scheduler-config
.reports/
.cache/db-build/

# Knowledge-graph build artifact. Auto-generated by `bun run db build`
# (scripts/build-knowledge-index.ts) from course/knowledge/**/node.md.
# Regenerated on every `bun run db reset` / `bun run dev` knowledge precheck;
# tracking it in git produced phantom dirty-file drift on every agent's
# `git status`. The file is purely derived (no consumers read it at build or
# runtime); the canonical source is the node.md set. Regenerate locally with
# `bun run db build`.
course/knowledge/graph-index.md
