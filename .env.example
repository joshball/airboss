# Database
# OrbStack Postgres, port 5435 per @ab/constants PORTS.DB
DATABASE_URL=postgresql://airboss:airboss@localhost:5435/airboss

# Better-auth session signing secret.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32

# Email transport (optional in dev -- falls back to console logging).
# RESEND_API_KEY=re_your_key_here

# Logging (debug | info | warn | error). Default: info.
LOG_LEVEL=info

# Connection pool override (optional). Default: 10.
# DB_POOL_SIZE=10
